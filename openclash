config openclash 'config'
	# ========== 基本 ==========
	option enable '1'
	option core_type 'Meta'
	option core_version 'linux-arm64'
	option release_branch 'master'
	option proxy_mode 'rule'
	option operation_mode 'fake-ip'
	option en_mode 'fake-ip-tun'

	# ========== 端口（与你的 YAML mixed-port 不冲突） ==========
	option http_port '7890'
	option socks_port '7891'
	option proxy_port '7892'
	option mixed_port '7893'
	option tproxy_port '7895'
	option dns_port '7874'
	option cn_port '9090'

	# ========== 日志 ==========
	option log_level '0'
	option log_size '1024'

	# ========== 网络行为 ==========
	option enable_tcp_concurrent '1'
	option enable_unified_delay '1'
	option stack_type 'system'
	option disable_quic_go_gso '1'

	# ========== fake-ip（只执行，不决策） ==========
	option store_fakeip '1'
	option fakeip_range '198.18.0.1/16'
	option fakeip_range6 'fdfe:dcba:9876::1/64'
	option custom_fakeip_filter '1'
	option custom_fakeip_filter_mode 'blacklist'

	# ========== DNS（⚠️ 关键：插件不再接管） ==========
	option enable_custom_dns '0'
	option enable_redirect_dns '0'
	option redirect_dns '0'
	option append_wan_dns '0'
	option append_default_dns '0'
	option dnsmasq_filter_aaaa '1'
	option dnsmasq_cachesize '1000'
	option disable_masq_cache '1'

	# ========== IPv6（与你 YAML 保持一致：关闭） ==========
	option ipv6_enable '0'
	option ipv6_dns '0'
	option ipv6_mode '0'
	option china_ip6_route '0'

	# ========== GEO / GEOSITE / ASN（完全交给 YAML） ==========
	option enable_geoip_dat '0'
	option geo_auto_update '0'
	option geoip_auto_update '0'
	option geosite_auto_update '0'
	option geoasn_auto_update '0'
	option chnr_auto_update '0'
	option geodata_loader 'memconservative'

	option geo_custom_url ''
	option geoip_custom_url ''
	option geosite_custom_url ''
	option geoasn_custom_url ''
	option chnr_custom_url ''
	option chnr6_custom_url ''

	# ========== Sniffer ==========
	option enable_meta_sniffer '0'
	option enable_meta_sniffer_pure_ip '0'
	option enable_meta_sniffer_custom '0'

	# ========== 路由行为 ==========
	#旁路由需要设置为1
	option intranet_allowed '0'
	#旁路由需要设置为0
	option router_self_proxy '1'
	option bypass_gateway_compatible '0'
	option china_ip_route '1'
	option skip_proxy_address '1'
	option lan_interface_name 'br-lan'
	option interface_name '0'

	# ========== 自动化（关闭，防止扰动） ==========
	option update '0'
	option auto_update '0'
	option auto_restart '1'
	option auto_restart_week_time '*'
	option auto_restart_day_time '5'

	# ========== UI ==========
	option dashboard_type 'Official'
	option yacd_type 'Meta'
	option dashboard_forward_ssl '0'
	option dashboard_password 'DWBj3LgA'

	# ========== 配置路径 ==========
	option config_path '/etc/openclash/config/configfull.yaml'

	# ========== 行为一致性 ==========
	option enable_respect_rules '1'
	option find_process_mode '0'
	option global_client_fingerprint 'chrome'

	# ========== Smart / 实验性功能（全部关闭） ==========
	option smart_enable '0'
	option auto_smart_switch '0'
	option smart_strategy '0'
	option smart_prefer_asn '0'
	option smart_enable_lgbm '0'
	option smart_collect '0'
	option lgbm_auto_update '0'

	# ========== GitHub/CDN（无规则依赖，不重要） ==========
	option github_address_mod 'https://cdn.jsdelivr.net/'
	option urltest_address_mod '0'
	option urltest_interval_mod '0'

	# ========== 其他 ==========
	option rule_source '0'
	option enable_rule_proxy '0'
	option enable_custom_clash_rules '0'
	option other_rule_auto_update '0'
	option servers_update '0'
	option servers_if_update '0'
	option delay_start '0'
	option restart '0'